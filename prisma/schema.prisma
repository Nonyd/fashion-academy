// PFA Portal – Prisma schema
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
  MANAGEMENT
}

enum AdmissionStatus {
  PENDING
  ACCEPTED
  REJECTED
  WAITLISTED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ProjectStatus {
  SUBMITTED
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

enum EnrollmentStatus {
  ACTIVE
  GRADUATED
  WITHDRAWN
  SUSPENDED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  profileImage String?
  role         Role
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  student    Student?
  teacher    Teacher?
  management Management?

  @@map("users")
}

model Student {
  id                String           @id @default(cuid())
  userId            String           @unique
  regNumber         String           @unique
  program           String
  intakeYear        Int
  enrollmentStatus  EnrollmentStatus @default(ACTIVE)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollments Enrollment[]
  scores     Score[]
  projects   Project[]
  payments   Payment[]

  @@map("students")
}

model Teacher {
  id        String   @id @default(cuid())
  userId    String   @unique
  title     String?
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courses Course[]

  @@map("teachers")
}

model Management {
  id         String   @id @default(cuid())
  userId     String   @unique
  title      String?
  department String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("management")
}

model Alumni {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  email          String   @unique
  phone          String?
  regNumber      String   @unique
  programme      String
  graduationYear Int
  city           String
  country        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("alumni")
}

model Admission {
  id                 String         @id @default(cuid())
  firstName          String
  lastName           String
  email              String
  phone              String
  dateOfBirth        DateTime?
  nationality        String?
  country            String
  program            String
  intakeYear         Int
  previousEducation  String?
  portfolioUrl       String?
  statementOfPurpose String?
  status             AdmissionStatus @default(PENDING)
  paymentStatus      PaymentStatus   @default(PENDING)
  reviewNotes        String?
  reviewedAt         DateTime?
  reviewedById       String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  payments Payment[]

  @@map("admissions")
}

model Course {
  id          String   @id @default(cuid())
  title       String
  code        String   @unique
  description String?
  program     String
  semester    Int
  teacherId   String?
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teacher     Teacher?     @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  enrollments Enrollment[]
  scores      Score[]
  projects    Project[]

  @@map("courses")
}

model Enrollment {
  studentId   String
  courseId    String
  enrolledAt  DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@id([studentId, courseId])
  @@map("enrollments")
}

model Score {
  id             String   @id @default(cuid())
  studentId      String
  courseId      String
  score         Int      // 0-100
  letterGrade   String
  assessmentType String
  semester      Int
  feedback      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("scores")
}

model Project {
  id              String        @id @default(cuid())
  studentId       String
  courseId        String
  title           String
  description     String?
  fileUrl         String
  thumbnailUrl    String?
  status          ProjectStatus @default(SUBMITTED)
  teacherFeedback String?
  grade           Int?
  submittedAt     DateTime      @default(now())
  reviewedAt      DateTime?
  reviewedById    String?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("projects")
}

model Payment {
  id             String        @id @default(cuid())
  amount         Float
  currency       String        @default("NGN")
  purpose        String
  status         PaymentStatus @default(PENDING)
  provider       String        // PAYSTACK | STRIPE
  transactionRef String?       @unique
  admissionId    String?
  studentId      String?
  email          String
  name           String
  metadata       Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  admission Admission? @relation(fields: [admissionId], references: [id])
  student   Student?   @relation(fields: [studentId], references: [id])

  @@map("payments")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}

model MailTemplate {
  id        String   @id @default(cuid())
  event     String   @unique
  subject   String
  bodyHtml  String
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@map("mail_templates")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}
